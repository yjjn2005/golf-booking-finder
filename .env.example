# ============================
# 골프 API 키 설정 (실제 발급 후 .env 파일에 복사)
# ============================

# 골프몬 파트너 API
# 발급: https://partner.golfmon.co.kr/api
VITE_GOLFMON_API_KEY=your_golfmon_api_key_here
VITE_GOLFMON_BASE_URL=https://api.golfmon.co.kr/v1

# 골팡 파트너 API
# 발급: https://www.golfang.com/partner
VITE_GOLFANG_API_KEY=your_golfang_api_key_here
VITE_GOLFANG_BASE_URL=https://api.golfang.com/v2

# 조인부킹 API
# 발급: https://joinbooking.com/developers
VITE_JOINBOOKING_API_KEY=your_joinbooking_api_key_here
VITE_JOINBOOKING_BASE_URL=https://api.joinbooking.com/v1

# 기준 좌표 (송파구청)
VITE_BASE_LAT=37.5145
VITE_BASE_LNG=127.1059
